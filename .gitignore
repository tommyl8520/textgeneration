## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This ignore file can be used at the root of the solution.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
Log/
logs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image build caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on interactive terminals
$RECYCLE.BIN/

# Others
*.Cache
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.dot

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
/wwwroot/lib/

# StyleCop
StyleCop.Cache

# JetBrains Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode
.JustCode

# TeamCity
_TeamCity*

# Omoni
.omni

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an extension point.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Config to restore packages
# !NuGet.Config

# BOWER
bower_components/

# Node.js
node_modules/
npm-debug.log

# Entity Framework skipping of database backup files
*.es3

# Service Fabric
/PublishProfiles/
/ApplicationParameters/

# Microsoft Azure
*.azurePubxml

# Others
IPCH/
.db
.opendb
